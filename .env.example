# Copilot proxy (run: npm run server)
# GitHub token with access to GitHub Models — NEVER commit real values.
GITHUB_TOKEN=

# Optional: port for server/index.js (default 3001)
COPILOT_PORT=3001

# Expo app: base URL of the copilot proxy (no token here).
# Same host/path base is used for POST /api/copilot and POST /api/daily-tip.
# iOS simulator: http://localhost:3001
# Android emulator: http://10.0.2.2:3001
# Physical device: http://<your-LAN-IP>:3001
EXPO_PUBLIC_COPILOT_API_URL=http://localhost:3001
